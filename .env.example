# -----------------------------------------------------------------------------
# Copy to `.env.local` (local) or set in Vercel / hosting dashboard.
# Never commit `.env.local` — it is gitignored.
# -----------------------------------------------------------------------------

# GitHub REST (public). Used by /api/github — no token required for basic reads.
# https://docs.github.com/en/rest
GITHUB_USERNAME=AbIsheKVaIdyA

# Medium RSS (no API key). Default feed = https://medium.com/feed/@abhishekcv.us
MEDIUM_USERNAME=abhishekcv.us
# Or set full feed URL explicitly:
# MEDIUM_FEED_URL=https://medium.com/feed/@abhishekcv.us

# Weather — Open-Meteo (no API key). Defaults: Dallas, TX
# https://open-meteo.com/
WEATHER_LAT=32.7767
WEATHER_LON=-96.797
WEATHER_LABEL=Dallas, TX

# --- Spotify “now playing” ---------------------------------------------------
# Dashboard: https://developer.spotify.com/dashboard
#
# 1) Create an app. Under “Redirect URIs” add EXACTLY (no typo, match prod domain):
#    https://YOUR-DOMAIN.com/api/spotify/callback
#
# 2) Set these three in Vercel (or .env.local):
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Must match the Redirect URI you added in Spotify (character-for-character):
SPOTIFY_REDIRECT_URI=https://YOUR-DOMAIN.com/api/spotify/callback
#
# 3) Deploy. Then open in the browser (on production):
#    https://YOUR-DOMAIN.com/api/spotify/auth
#    Log in to Spotify → you land on /api/spotify/callback with a page showing:
#    SPOTIFY_REFRESH_TOKEN=...
#
# 4) Copy that value into Vercel as SPOTIFY_REFRESH_TOKEN, redeploy.
#
# Optional: if you set SPOTIFY_SETUP_SECRET, open:
#    https://YOUR-DOMAIN.com/api/spotify/auth?secret=YOUR_SECRET
#    so random visitors can’t start the OAuth flow.
SPOTIFY_REFRESH_TOKEN=
# SPOTIFY_SETUP_SECRET=
