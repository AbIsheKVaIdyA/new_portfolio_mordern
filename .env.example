# -----------------------------------------------------------------------------
# Optional — defaults match your public profiles / Dallas weather
# Copy to `.env.local` and fill in secrets. Never commit `.env.local`.
# -----------------------------------------------------------------------------

# GitHub REST (public). Used by /api/github — no token required for basic reads.
# https://docs.github.com/en/rest
GITHUB_USERNAME=AbIsheKVaIdyA

# Medium RSS (no API key). Default feed = https://medium.com/feed/@abhishekcv.us
MEDIUM_USERNAME=abhishekcv.us
# Or set full feed URL explicitly:
# MEDIUM_FEED_URL=https://medium.com/feed/@abhishekcv.us

# Weather — Open-Meteo (no API key). Defaults: Dallas, TX
# https://open-meteo.com/
WEATHER_LAT=32.7767
WEATHER_LON=-96.797
WEATHER_LABEL=Dallas, TX

# Spotify Web API — “now playing” via refresh token
# Dashboard: https://developer.spotify.com/dashboard
# Create an app, add Redirect URI (e.g. http://127.0.0.1:3000/api/spotify/callback for local dev).
# Required scopes: user-read-currently-playing user-read-playback-state
# After OAuth, exchange the authorization code for a refresh token and paste it here.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
